# Copy to .env and fill in if you want the LLM-powered ops assistant.
# Without a key, the assistant falls back to a deterministic rule-based engine.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Database location (SQLite by default). Override to point at Postgres, e.g.
# DATABASE_URL=postgresql+psycopg://user:pass@localhost:5432/control_tower
DATABASE_URL=sqlite:///data/control_tower.db

# Reproducible simulation
SIM_SEED=42
SIM_DAYS=30
SIM_TRUCKS=50
